# Postgres
DATABASE_URL=

# Redis
REDIS_URL=

# Auth secrets (generated via openssl rand -base64 48)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Mailtrap (fill in after registering at mailtrap.io)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_TRANSPORT=

# Admin SPA origin (CORS allow-list for api-public). Default http://localhost:5173
WEB_ADMIN_URL=

# Google OAuth (optional — sign-in via Google). Create a Web OAuth client at
# console.cloud.google.com; redirect URI = the web-public callback below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Admin SPA callback (register this redirect URI on the same OAuth client too).
GOOGLE_ADMIN_REDIRECT_URI=http://localhost:5173/auth/google/callback
