{
  "name": "@fandrop/events",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bus": {
      "types": "./dist/bus.d.ts",
      "import": "./dist/bus.js",
      "require": "./dist/bus.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ioredis": "^5.11.0"
  },
  "devDependencies": {
    "@fandrop/typescript-config": "workspace:*",
    "@types/node": "^24.12.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
